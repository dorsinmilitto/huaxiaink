---
export interface Props {
  title: string;
  description?: string;
  image?: string;
  lang: string;
}

const { title, description, image, lang } = Astro.props;
const l = lang as 'en' | 'zh';
const defaultDesc = l === 'zh'
  ? '用当代视角，发现真实中国 — 精选故事配文化解读'
  : 'Discover China Through Authentic Voices — Stories of Chinese culture with context you won\'t find anywhere else';
const desc = description || defaultDesc;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Build alternate language links
const altLang = l === 'en' ? 'zh' : 'en';
const altPath = Astro.url.pathname.replace(`/${l}/`, `/${altLang}/`);
const altURL = new URL(altPath, Astro.site);
---

<!doctype html>
<html lang={l === 'zh' ? 'zh-CN' : 'en'}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={desc} />
  <link rel="canonical" href={canonicalURL} />
  <link rel="alternate" hreflang={l === 'zh' ? 'zh-CN' : 'en'} href={canonicalURL} />
  <link rel="alternate" hreflang={altLang === 'zh' ? 'zh-CN' : 'en'} href={altURL} />
  <link rel="alternate" hreflang="x-default" href={new URL('/en' + Astro.url.pathname.replace(/^\/(en|zh)/, ''), Astro.site).href} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Crimson+Pro:ital,wght@0,300;0,400;0,600;0,700;1,400&family=Inter:wght@400;500;600&family=Noto+Serif+SC:wght@400;600;700&display=swap" rel="stylesheet" />

  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={desc} />
  <meta property="og:locale" content={l === 'zh' ? 'zh_CN' : 'en_US'} />
  <meta property="og:locale:alternate" content={l === 'zh' ? 'en_US' : 'zh_CN'} />
  {image && <meta property="og:image" content={new URL(image, Astro.site)} />}

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={desc} />

  <title>{title} | HuaxiaInk</title>
</head>
<body>
  <nav class="main-nav">
    <div class="nav-inner">
      <a href={`/${l}`} class="logo">
        <span class="logo-ink">墨</span>
        <span class="logo-text">{l === 'zh' ? '华夏墨韵' : 'HuaxiaInk'}</span>
      </a>
      <div class="nav-links">
        <a href={`/${l}/events`}>{l === 'zh' ? '热点' : 'Events'}</a>
        <a href={`/${l}/games`}>{l === 'zh' ? '游戏' : 'Games'}</a>
        <a href={`/${l}/music`}>{l === 'zh' ? '音乐' : 'Music'}</a>
        <a href={`/${l}/travel`}>{l === 'zh' ? '旅行' : 'Travel'}</a>
        <a href={`/${l}/festivals`}>{l === 'zh' ? '节日' : 'Festivals'}</a>
        <a href={`/${l}/food`}>{l === 'zh' ? '美食' : 'Food'}</a>
      </div>
      <a href={altPath} class="lang-switch" title={altLang === 'zh' ? '切换到中文' : 'Switch to English'}>
        {altLang === 'zh' ? '中文' : 'EN'}
      </a>
    </div>
  </nav>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-brand">
        <span class="logo-ink">墨</span> {l === 'zh' ? '华夏墨韵' : 'HuaxiaInk'}
      </div>
      <p class="footer-tagline">{l === 'zh' ? '用当代视角，发现真实中国' : 'Discover China Through Authentic Voices'}</p>
      <nav class="footer-links">
        <a href={`/${l}/about`}>{l === 'zh' ? '关于我们' : 'About'}</a>
        <a href={`/${l}/contact`}>{l === 'zh' ? '联系我们' : 'Contact'}</a>
        <a href={`/${l}/terms`}>{l === 'zh' ? '使用条款' : 'Terms'}</a>
        <a href={`/${l}/privacy`}>{l === 'zh' ? '隐私政策' : 'Privacy'}</a>
        <a href={`/${l}/affiliate-disclosure`}>{l === 'zh' ? '联盟披露' : 'Affiliate Disclosure'}</a>
      </nav>
      <p class="footer-copy">&copy; {new Date().getFullYear()} HuaxiaInk. {l === 'zh' ? '版权所有' : 'All rights reserved.'}</p>
    </div>
  </footer>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
