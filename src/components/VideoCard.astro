---
export interface Props {
  id?: string;
  title: string;
  channel: string;
  duration?: string;
  category: string;
  tags?: string[];
  slug: string;
  lang: string;
  coverImage?: string;
}

const { id, title, channel, duration, category, tags = [], slug, lang, coverImage } = Astro.props;
// Priority: self-hosted WebP > coverImage prop > empty
const thumbnail = id
  ? `/covers/${id}.webp`
  : coverImage || '';
const href = `/${lang}/${category}/${slug}/`;
---

<a href={href} class="video-card">
  {thumbnail && (
    <div class="video-thumb">
      <img src={thumbnail} alt={title} loading="lazy" width="1280" height="720" />
      {duration && <span class="video-duration">{duration}</span>}
    </div>
  )}
  <div class="video-body">
    <h3>{title}</h3>
    <p class="video-meta">{channel}</p>
    {tags.length > 0 && (
      <div style="margin-top:0.5rem">
        {tags.slice(0, 3).map(tag => <span class="video-tag">{tag}</span>)}
      </div>
    )}
  </div>
</a>
