---
export interface Props {
  id: string;
  title: string;
  channel: string;
  duration: string;
  category: string;
  tags?: string[];
  slug: string;
  lang: string;
}

const { id, title, channel, duration, category, tags = [], slug, lang } = Astro.props;
const thumbnail = `https://i.ytimg.com/vi/${id}/hqdefault.jpg`;
const href = `/${lang}/${category}/${slug}`;
---

<a href={href} class="video-card">
  <div class="video-thumb">
    <img src={thumbnail} alt={title} loading="lazy" width="480" height="270" />
    <span class="video-duration">{duration}</span>
  </div>
  <div class="video-body">
    <h3>{title}</h3>
    <p class="video-meta">{channel}</p>
    {tags.length > 0 && (
      <div style="margin-top:0.5rem">
        {tags.slice(0, 3).map(tag => <span class="video-tag">{tag}</span>)}
      </div>
    )}
  </div>
</a>
