---
interface Props {
  lang: 'en' | 'zh';
  mapping: string;
  term: string;
}

const { lang, mapping, term } = Astro.props;
---

<div class="giscus"></div>
<script
  is:inline
  src="https://giscus.app/client.js"
  data-repo="dorsinmilitto/huaxiaink"
  data-repo-id="R_kgDOTBcQtA"
  data-category="Announcements"
  data-category-id="DIC_kwDOTBcQtM4C_s_H"
  data-mapping={mapping}
  data-term={term}
  data-strict="0"
  data-reactions-enabled="1"
  data-emit-metadata="0"
  data-input-position="top"
  data-theme="light"
  data-lang={lang}
  data-loading="lazy"
  async
></script>
