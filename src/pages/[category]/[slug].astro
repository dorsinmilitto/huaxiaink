---
import BaseLayout from '../../layouts/BaseLayout.astro';
import YouTubeEmbed from '../../components/YouTubeEmbed.astro';
import AffiliateCard from '../../components/AffiliateCard.astro';
import VideoCard from '../../components/VideoCard.astro';
import { getCollection } from 'astro:content';

const categoryNames: Record<string, string> = {
  events: 'Hot Events',
  games: 'Games',
  music: 'Music',
  travel: 'Travel',
  festivals: 'Festivals',
  food: 'Food',
};

export async function getStaticPaths() {
  const cats = ['events', 'games', 'music', 'travel', 'festivals', 'food'] as const;
  const paths: any[] = [];

  for (const cat of cats) {
    const entries = await getCollection(cat);
    for (const entry of entries) {
      const { Content } = await entry.render();
      paths.push({
        params: { category: cat, slug: entry.slug },
        props: { frontmatter: entry.data, Content },
      });
    }
  }
  return paths;
}

const { category, slug } = Astro.params;
const { frontmatter, Content } = Astro.props;
const catName = categoryNames[category!] || category;

// Get related videos from same category
const relatedEntries = await getCollection(category as any);
const related = relatedEntries
  .filter(e => e.slug !== slug)
  .map(e => ({ ...e.data, slug: e.slug, category }))
  .sort((a, b) => b.publishedAt.getTime() - a.publishedAt.getTime())
  .slice(0, 4);

// Schema.org VideoObject
const schema = {
  "@context": "https://schema.org",
  "@type": "VideoObject",
  "name": frontmatter.title,
  "description": `Watch and learn about ${frontmatter.title} on HuaxiaInk`,
  "thumbnailUrl": `https://i.ytimg.com/vi/${frontmatter.youtubeId}/hqdefault.jpg`,
  "embedUrl": `https://www.youtube.com/embed/${frontmatter.youtubeId}`,
  "uploadDate": frontmatter.publishedAt.toISOString(),
  "contentUrl": `https://www.youtube.com/watch?v=${frontmatter.youtubeId}`,
};
---

<BaseLayout title={frontmatter.title} description={`${frontmatter.title} by ${frontmatter.channel} — Cultural analysis on HuaxiaInk`}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <div class="video-detail">
    <!-- Breadcrumb -->
    <nav class="breadcrumb">
      <a href="/">Home</a> <span>/</span>
      <a href={`/${category}`}>{catName}</a> <span>/</span>
      <span>{frontmatter.title}</span>
    </nav>

    <!-- Info -->
    <div class="video-info">
      <h1>{frontmatter.title}</h1>
      <div class="video-meta-detail">
        <span>by {frontmatter.channel}</span>
        <span>{frontmatter.publishedAt.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
        {frontmatter.duration && <span>{frontmatter.duration}</span>}
      </div>
      <div>
        {frontmatter.tags.map((tag: string) => <span class="video-tag">{tag}</span>)}
      </div>
    </div>

    <!-- Content (analysis + takeaways) -->
    <div class="analysis">
      <h2>Cultural Context</h2>
      <Content />
    </div>

    <!-- Affiliate -->
    {frontmatter.affiliate && frontmatter.affiliate.length > 0 && (
      <div class="affiliate-section">
        <h3>Dive Deeper</h3>
        <p>Explore related products handpicked for this topic:</p>
        {frontmatter.affiliate.map((item: any) => (
          <AffiliateCard title={item.title} asin={item.asin} url={item.url} />
        ))}
        <p style="font-size:0.75rem;color:var(--text-muted);margin-top:0.75rem">
          As an Amazon Associate, we earn from qualifying purchases.
        </p>
      </div>
    )}

    <!-- Related -->
    {related.length > 0 && (
      <section class="section" style="padding-left:0;padding-right:0">
        <h2 class="section-title">You May Also Like</h2>
        <div class="video-grid">
          {related.map(v => (
            <VideoCard
              id={v.youtubeId}
              title={v.title}
              channel={v.channel}
              duration={v.duration}
              category={v.category}
              tags={v.tags}
              slug={v.slug}
            />
          ))}
        </div>
      </section>
    )}

    <!-- Video Player (last) -->
    {frontmatter.youtubeId && (
      <section class="section" style="padding-left:0;padding-right:0">
        <YouTubeEmbed youtubeId={frontmatter.youtubeId} title={frontmatter.title} />
      </section>
    )}
  </div>
</BaseLayout>
