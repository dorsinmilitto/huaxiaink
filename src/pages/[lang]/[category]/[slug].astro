---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import YouTubeEmbed from '../../../components/YouTubeEmbed.astro';
import AffiliateCard from '../../../components/AffiliateCard.astro';
import VideoCard from '../../../components/VideoCard.astro';
import GiscusComments from '../../../components/GiscusComments.astro';
import ShareButtons from '../../../components/ShareButtons.astro';
import FloatingSidebar from '../../../components/FloatingSidebar.astro';
import { getCollection } from 'astro:content';
import { t, type Lang } from '../../../i18n/utils';

export async function getStaticPaths() {
  const cats = ['events', 'games', 'music', 'travel', 'festivals', 'food', 'kung-fu'] as const;
  const paths: any[] = [];

  for (const cat of cats) {
    for (const lang of ['en', 'zh'] as const) {
      const entries = await getCollection(cat, ({ data }) => data.lang === lang);
      for (const entry of entries) {
        const slug = entry.data.lang === 'zh' ? entry.slug.replace(/-zh$/, '') : entry.slug;
        const { Content } = await entry.render();
        paths.push({
          params: { lang, category: cat, slug },
          props: { frontmatter: entry.data, Content },
        });
      }
    }
  }
  return paths;
}

const { lang, category, slug } = Astro.params;
const { frontmatter, Content } = Astro.props;
const l = lang as Lang;

// Get related videos from same category and language
const relatedEntries = await getCollection(category as any, ({ data }) => data.lang === l);
const related = relatedEntries
  .filter(e => {
    const s = e.data.lang === 'zh' ? e.slug.replace(/-zh$/, '') : e.slug;
    return s !== slug;
  })
  .map(e => ({
    ...e.data,
    slug: e.data.lang === 'zh' ? e.slug.replace(/-zh$/, '') : e.slug,
    category,
  }))
  .sort((a, b) => b.publishedAt.getTime() - a.publishedAt.getTime())
  .slice(0, 4);

const ogImage = frontmatter.coverImage
  || (frontmatter.youtubeId ? `https://i.ytimg.com/vi/${frontmatter.youtubeId}/hqdefault.jpg` : undefined);

const videoSchema = frontmatter.youtubeId ? {
  "@context": "https://schema.org",
  "@type": "VideoObject",
  "name": frontmatter.title,
  "description": `${t(l, 'detail.video_analysis')} ${frontmatter.title} ${t(l, 'detail.on')}`,
  "thumbnailUrl": `https://i.ytimg.com/vi/${frontmatter.youtubeId}/hqdefault.jpg`,
  "embedUrl": `https://www.youtube.com/embed/${frontmatter.youtubeId}`,
  "uploadDate": frontmatter.publishedAt.toISOString(),
  "contentUrl": `https://www.youtube.com/watch?v=${frontmatter.youtubeId}`,
  ...(frontmatter.duration ? { "duration": `PT${frontmatter.duration.replace(/:(\d+):(\d+)/, '$1H$2M').replace(/(\d+):(\d+)/, '$1M$2S')}` } : {}),
} : null;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": t(l, 'breadcrumb.home'), "item": `https://www.huaxiaink.com/${l}` },
    { "@type": "ListItem", "position": 2, "name": t(l, `cat.${category}` as any), "item": `https://www.huaxiaink.com/${l}/${category}` },
    { "@type": "ListItem", "position": 3, "name": frontmatter.title, "item": `https://www.huaxiaink.com/${l}/${category}/${slug}` },
  ],
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": frontmatter.title,
  "description": frontmatter.description || `${frontmatter.title} — ${t(l, 'detail.on')}`,
  "datePublished": frontmatter.publishedAt.toISOString(),
  "dateModified": frontmatter.publishedAt.toISOString(),
  "author": { "@type": "Organization", "name": "HuaxiaInk Editorial", "url": "https://www.huaxiaink.com" },
  "publisher": { "@type": "Organization", "name": "HuaxiaInk", "url": "https://www.huaxiaink.com", "logo": { "@type": "ImageObject", "url": "https://www.huaxiaink.com/favicon.svg" } },
  "mainEntityOfPage": `https://www.huaxiaink.com/${l}/${category}/${slug}`,
  "inLanguage": l === 'zh' ? 'zh-CN' : 'en',
  "articleSection": category,
  ...(frontmatter.tags.length > 0 ? { "keywords": frontmatter.tags.join(', ') } : {}),
  ...(ogImage ? { "image": ogImage } : {}),
  ...(frontmatter.channel ? { "contributor": { "@type": "Organization", "name": frontmatter.channel } } : {}),
};

const articleDesc = frontmatter.description || `${frontmatter.title} — ${t(l, 'detail.on')}`;
---

<BaseLayout title={frontmatter.title} description={articleDesc} lang={l} image={ogImage}
  type="article"
  publishedTime={frontmatter.publishedAt.toISOString()}
  modifiedTime={frontmatter.publishedAt.toISOString()}
  author="HuaxiaInk Editorial"
  section={category}
  tags={frontmatter.tags}
>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  {videoSchema && <script type="application/ld+json" set:html={JSON.stringify(videoSchema)} />}

  <FloatingSidebar url={`https://www.huaxiaink.com/${l}/${category}/${slug}`} title={frontmatter.title} lang={l} hasAffiliate={frontmatter.affiliate && frontmatter.affiliate.length > 0} />

  <div class="video-detail">
    <nav class="breadcrumb">
      <a href={`/${l}`}>{t(l, 'breadcrumb.home')}</a> <span>/</span>
      <a href={`/${l}/${category}`}>{t(l, `cat.${category}` as any)}</a> <span>/</span>
      <span>{frontmatter.title}</span>
    </nav>

    <div class="video-info">
      <h1>{frontmatter.title}</h1>
      <div class="video-meta-detail">
        <span>{t(l, 'detail.source')} {frontmatter.channel} (YouTube)</span>
        <span>{frontmatter.publishedAt.toLocaleDateString(l === 'zh' ? 'zh-CN' : 'en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
        {frontmatter.duration && <span>{frontmatter.duration}</span>}
      </div>
      <div>
        {frontmatter.tags.map((tag: string) => <a href={`/${l}/tag/${tag.toLowerCase()}`} class="video-tag">{tag}</a>)}
      </div>
      <ShareButtons url={`https://www.huaxiaink.com/${l}/${category}/${slug}`} title={frontmatter.title} lang={l} />
    </div>

    <div class="analysis">
      <Content />
    </div>

    {frontmatter.youtubeId && (
      <section class="section" style="padding-left:0;padding-right:0">
        <YouTubeEmbed youtubeId={frontmatter.youtubeId} title={frontmatter.title} />
      </section>
    )}

    {related.length > 0 && (
      <section class="section" style="padding-left:0;padding-right:0">
        <h2 class="section-title">{t(l, 'section.related')}</h2>
        <div class="video-grid">
          {related.map(v => (
            <VideoCard
              id={v.youtubeId}
              title={v.title}
              channel={v.channel}
              duration={v.duration}
              category={v.category}
              tags={v.tags}
              slug={v.slug}
              lang={l}
              coverImage={v.coverImage}
            />
          ))}
        </div>
      </section>
    )}

    {frontmatter.affiliate && frontmatter.affiliate.length > 0 && (
      <div class="affiliate-section" id="affiliate-section">
        <h3>{t(l, 'section.dive_deeper')}</h3>
        <p>{t(l, 'section.dive_deeper_desc')}</p>
        <div class="affiliate-cards">
          {frontmatter.affiliate.map((item: any) => (
            <AffiliateCard title={item.title} asin={item.asin} url={item.url} imageUrl={item.imageUrl} price={item.price} />
          ))}
        </div>
        <p style="font-size:0.75rem;color:var(--text-muted);margin-top:0.75rem">
          {t(l, 'section.affiliate_disclosure')}
        </p>
      </div>
    )}

    <div class="comments-section">
      <GiscusComments lang={l} mapping="pathname" term={`/${l}/${category}/${slug}`} />
    </div>
  </div>
</BaseLayout>
