---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { type Lang } from '../../../i18n/utils';

export async function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'zh' } }];
}

const { lang } = Astro.params;
const l = lang as Lang;
const isZh = l === 'zh';

const pageData = isZh ? {
  title: '中国节日查询',
  description: '查询任意年份的中国传统节日公历日期，包括春节、元宵节、清明、端午、七夕、中秋、重阳等，附带节日简介和倒计时。',
  h1: '中国节日查询',
  intro: '选择年份，查看该年所有中国传统节日对应的公历日期、星期和距今天数。',
  yearLabel: '选择年份',
  seoH2: '中国传统节日简介',
  seoP1: '中国传统节日以农历为基础，与二十四节气紧密关联。春节（正月初一）是一年最重要的节日，象征辞旧迎新；元宵节（正月十五）以赏灯、猜灯谜为主要活动；清明节为节气节日，扫墓祭祖；端午节（五月初五）纪念屈原，有赛龙舟、吃粽子的习俗。',
  seoP2: '七夕节（七月初七）源自牛郎织女的传说，被称为中国情人节；中秋节（八月十五）以赏月、吃月饼为传统，象征团圆；重阳节（九月初九）有登高、赏菊的习俗，也是敬老节。此外还有腊八节、除夕等重要节点。',
  seoP3: '由于农历与公历之间存在差异，每年的传统节日在公历中的日期都不相同。本工具精确计算了1900年至2100年所有传统节日对应的公历日期，方便查询和安排。',
  relatedTitle: '其他工具',
  tableFestival: '节日',
  tableLunarDate: '农历日期',
  tableSolarDate: '公历日期',
  tableWeekday: '星期',
  tableCountdown: '倒计时',
  today: '今天',
  daysAgo: '天前',
  daysLater: '天后',
} : {
  title: 'Chinese Festival Finder',
  description: 'Find the Gregorian dates of all major Chinese traditional festivals for any year — Spring Festival, Lantern, Qingming, Dragon Boat, Mid-Autumn, and more.',
  h1: 'Chinese Festival Finder',
  intro: 'Select a year to see all major Chinese traditional festivals with their exact Gregorian dates, weekdays, and countdown.',
  yearLabel: 'Select Year',
  seoH2: 'About Chinese Traditional Festivals',
  seoP1: 'Chinese traditional festivals are based on the lunar calendar and closely tied to the 24 solar terms. Spring Festival (Lunar New Year) is the most important, symbolizing renewal. The Lantern Festival features lantern displays and riddles. Qingming Festival, a solar term, is for tomb-sweeping and ancestor worship. The Dragon Boat Festival commemorates Qu Yuan with dragon boat racing and zongzi.',
  seoP2: 'The Qixi Festival, from the legend of the Cowherd and Weaver Girl, is often called Chinese Valentine\'s Day. The Mid-Autumn Festival is celebrated with mooncakes and moon-gazing, symbolizing family reunion. The Double Ninth Festival involves climbing mountains and chrysanthemum viewing, and is also Elder\'s Day in China.',
  seoP3: 'Because the lunar calendar differs from the Gregorian calendar, the exact Gregorian dates of traditional festivals change every year. This tool precisely calculates the dates of all major Chinese festivals from 1900 to 2100.',
  relatedTitle: 'Other Tools',
  tableFestival: 'Festival',
  tableLunarDate: 'Lunar Date',
  tableSolarDate: 'Gregorian Date',
  tableWeekday: 'Weekday',
  tableCountdown: 'Countdown',
  today: 'Today',
  daysAgo: 'days ago',
  daysLater: 'days away',
};

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": pageData.title,
  "url": `https://www.huaxiaink.com/${l}/tools/festival-finder/`,
  "description": pageData.description,
  "applicationCategory": "UtilityApplication",
  "operatingSystem": "Web",
  "inLanguage": isZh ? "zh-CN" : "en",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
};
---

<BaseLayout title={pageData.title} description={pageData.description} lang={l}>
  <div class="tool-page">
    <nav class="breadcrumb">
      <a href={`/${l}/`}>{isZh ? '首页' : 'Home'}</a>
      <span class="sep">›</span>
      <a href={`/${l}/tools/`}>{isZh ? '工具' : 'Tools'}</a>
      <span class="sep">›</span>
      <span class="current">{pageData.h1}</span>
    </nav>

    <h1>{pageData.h1}</h1>
    <p class="tool-intro">{pageData.intro}</p>

    <div class="tool-container">
      <div class="form-row">
        <label for="festival-year">{pageData.yearLabel}</label>
        <div class="year-input-row">
          <button class="year-nav-btn" id="year-prev">‹</button>
          <input type="number" id="festival-year" min="1900" max="2100" value={new Date().getFullYear()} />
          <button class="year-nav-btn" id="year-next">›</button>
        </div>
      </div>

      <div class="festival-table-wrap">
        <table class="festival-table" id="festival-table">
          <thead>
            <tr>
              <th>{pageData.tableFestival}</th>
              <th>{pageData.tableLunarDate}</th>
              <th>{pageData.tableSolarDate}</th>
              <th>{pageData.tableWeekday}</th>
              <th>{pageData.tableCountdown}</th>
            </tr>
          </thead>
          <tbody id="festival-tbody"></tbody>
        </table>
      </div>
    </div>

    <section class="seo-content">
      <h2>{pageData.seoH2}</h2>
      <p>{pageData.seoP1}</p>
      <p>{pageData.seoP2}</p>
      <p>{pageData.seoP3}</p>
    </section>

    <section class="related-tools">
      <h2>{pageData.relatedTitle}</h2>
      <div class="related-grid">
        <a href={`/${l}/tools/lunar-converter/`} class="related-card">
          <span class="related-icon">📅</span>
          <span class="related-name">{isZh ? '农历转换器' : 'Lunar Converter'}</span>
        </a>
        <a href={`/${l}/tools/zodiac-calculator/`} class="related-card">
          <span class="related-icon">🐉</span>
          <span class="related-name">{isZh ? '生肖查询器' : 'Zodiac Calculator'}</span>
        </a>
      </div>
    </section>
  </div>

  <script is:inline src="/js/lunar.js"></script>
  <script is:inline define:vars={{ pd: pageData, isZh }}>
    document.addEventListener('DOMContentLoaded', function() {
      var festivals = [
        { lm: 1, ld: 1, nameZh: '春节', nameEn: 'Spring Festival', emoji: '🧨', lunarZh: '正月初一', lunarEn: '1st Month, Day 1' },
        { lm: 1, ld: 15, nameZh: '元宵节', nameEn: 'Lantern Festival', emoji: '🏮', lunarZh: '正月十五', lunarEn: '1st Month, Day 15' },
        { jieqi: true, nameZh: '清明节', nameEn: 'Qingming Festival', emoji: '🌿', lunarZh: '清明节气', lunarEn: 'Qingming Solar Term', startM: 4, startD: 4, endD: 6 },
        { lm: 5, ld: 5, nameZh: '端午节', nameEn: 'Dragon Boat Festival', emoji: '🐉', lunarZh: '五月初五', lunarEn: '5th Month, Day 5' },
        { lm: 7, ld: 7, nameZh: '七夕节', nameEn: 'Qixi Festival', emoji: '💕', lunarZh: '七月初七', lunarEn: '7th Month, Day 7' },
        { lm: 7, ld: 15, nameZh: '中元节', nameEn: 'Ghost Festival', emoji: '🕯️', lunarZh: '七月十五', lunarEn: '7th Month, Day 15' },
        { lm: 8, ld: 15, nameZh: '中秋节', nameEn: 'Mid-Autumn Festival', emoji: '🌕', lunarZh: '八月十五', lunarEn: '8th Month, Day 15' },
        { lm: 9, ld: 9, nameZh: '重阳节', nameEn: 'Double Ninth Festival', emoji: '🍂', lunarZh: '九月初九', lunarEn: '9th Month, Day 9' },
        { lm: 12, ld: 8, nameZh: '腊八节', nameEn: 'Laba Festival', emoji: '🥣', lunarZh: '腊月初八', lunarEn: '12th Month, Day 8' },
        { lastDay: true, nameZh: '除夕', nameEn: "New Year's Eve", emoji: '🎆', lunarZh: '腊月廿九/三十', lunarEn: '12th Month, Last Day' },
      ];

      var yearInput = document.getElementById('festival-year');
      var tbody = document.getElementById('festival-tbody');
      var today = new Date();
      today.setHours(0, 0, 0, 0);

      function calc() {
        var year = parseInt(yearInput.value);
        if (isNaN(year) || year < 1900 || year > 2100) return;

        var results = [];
        var lunarYear = LunarYear.fromYear(year);

        festivals.forEach(function(f) {
          var solar;
          if (f.jieqi) {
            // Find Qingming by checking April 4-6 for the solar term
            for (var d = f.startD; d <= f.endD; d++) {
              var testSolar = Solar.fromYmd(year, f.startM, d);
              var testLunar = testSolar.getLunar();
              var jq = testLunar.getJieQi();
              if (jq === '清明') { solar = testSolar; break; }
            }
            if (!solar) solar = Solar.fromYmd(year, 4, 5);
          } else if (f.lastDay) {
            // 除夕 = 农历年腊月最后一天，需过滤出属于当前农历年的月份
            var months = lunarYear.getMonths();
            var lastMonth;
            for (var mi = months.length - 1; mi >= 0; mi--) {
              if (months[mi].getYear() === year) {
                lastMonth = months[mi];
                break;
              }
            }
            var dayCount = lastMonth.getDayCount();
            var lunar = Lunar.fromYmd(year, lastMonth.getMonth(), dayCount);
            solar = lunar.getSolar();
          } else {
            var lunar = Lunar.fromYmd(year, f.lm, f.ld);
            solar = lunar.getSolar();
          }

          var solarDate = new Date(solar.getYear(), solar.getMonth() - 1, solar.getDay());
          var dayOfWeek = solar.getWeek();
          var diffDays = Math.round((solarDate - today) / (1000 * 60 * 60 * 24));

          var weekdayStr;
          if (isZh) {
            weekdayStr = '周' + ['日','一','二','三','四','五','六'][dayOfWeek];
          } else {
            weekdayStr = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'][dayOfWeek];
          }

          var countdownStr;
          if (diffDays === 0) {
            countdownStr = pd.today;
          } else if (diffDays > 0) {
            countdownStr = diffDays + ' ' + pd.daysLater;
          } else {
            countdownStr = Math.abs(diffDays) + ' ' + pd.daysAgo;
          }

          var dateStr = solar.getYear() + '-' + String(solar.getMonth()).padStart(2, '0') + '-' + String(solar.getDay()).padStart(2, '0');

          results.push({
            name: f.emoji + ' ' + (isZh ? f.nameZh : f.nameEn),
            lunarDate: isZh ? f.lunarZh : f.lunarEn,
            solarDate: dateStr,
            weekday: weekdayStr,
            countdown: countdownStr,
            diffDays: diffDays,
            isToday: diffDays === 0,
            isUpcoming: diffDays > 0
          });
        });

        results.sort(function(a, b) { return a.diffDays - b.diffDays; });

        var html = '';
        results.forEach(function(r) {
          var cls = r.isToday ? ' today' : (r.isUpcoming ? ' upcoming' : ' past');
          html += '<tr class="' + cls.trim() + '">'
            + '<td class="festival-name">' + r.name + '</td>'
            + '<td class="festival-lunar">' + r.lunarDate + '</td>'
            + '<td class="festival-solar">' + r.solarDate + '</td>'
            + '<td class="festival-week">' + r.weekday + '</td>'
            + '<td class="festival-countdown">' + r.countdown + '</td>'
            + '</tr>';
        });
        tbody.innerHTML = html;
      }

      yearInput.addEventListener('input', function() { calc(); });
      document.getElementById('year-prev').addEventListener('click', function() {
        yearInput.value = parseInt(yearInput.value) - 1;
        calc();
      });
      document.getElementById('year-next').addEventListener('click', function() {
        yearInput.value = parseInt(yearInput.value) + 1;
        calc();
      });

      calc();
    });
  </script>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <style>
    .tool-page { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem 4rem; }
    .breadcrumb { font-family: var(--font-sans); font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1.5rem; }
    .breadcrumb a { color: var(--link); }
    .breadcrumb .sep { margin: 0 0.5rem; }
    .breadcrumb .current { color: var(--text); }
    .tool-page h1 { font-size: 2rem; color: var(--ink-black); margin-bottom: 0.5rem; }
    .tool-intro { color: var(--text-muted); font-size: 1rem; margin-bottom: 2rem; }

    .tool-container {
      background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px;
      padding: 2rem; box-shadow: 0 2px 8px rgba(0,0,0,0.06); margin-bottom: 3rem;
    }

    .form-row { margin-bottom: 1.5rem; }
    .form-row label { display: block; font-family: var(--font-sans); font-size: 0.9rem; color: var(--text-muted); margin-bottom: 0.5rem; font-weight: 500; }
    .year-input-row { display: flex; align-items: center; gap: 0.5rem; }
    .year-input-row input {
      width: 120px; text-align: center; padding: 0.6rem; border: 1px solid var(--border); border-radius: 8px;
      font-size: 1.2rem; font-family: var(--font-sans); background: #fff; color: var(--text); font-weight: 600;
    }
    .year-input-row input:focus { outline: none; border-color: var(--vermillion); box-shadow: 0 0 0 3px rgba(192,57,43,0.1); }
    .year-nav-btn {
      width: 2.5rem; height: 2.5rem; border: 1px solid var(--border); border-radius: 8px;
      background: #fff; font-size: 1.3rem; cursor: pointer; color: var(--text-muted); transition: all 0.2s;
    }
    .year-nav-btn:hover { background: var(--vermillion); color: #fff; border-color: var(--vermillion); }

    .festival-table-wrap { overflow-x: auto; }
    .festival-table { width: 100%; border-collapse: collapse; font-family: var(--font-sans); }
    .festival-table th {
      text-align: left; padding: 0.7rem 0.5rem; border-bottom: 2px solid var(--border);
      font-size: 0.85rem; color: var(--text-muted); font-weight: 600; white-space: nowrap;
    }
    .festival-table td { padding: 0.7rem 0.5rem; border-bottom: 1px solid #f0ebe0; font-size: 0.9rem; color: var(--text); }
    .festival-table :global(tr.today) { background: rgba(39,174,96,0.18); }
    .festival-table :global(tr.today) .festival-countdown { color: #27ae60; font-weight: 700; font-size: 1rem; }
    .festival-table :global(tr.upcoming) { background: rgba(212,160,23,0.14); }
    .festival-table :global(tr.upcoming) .festival-countdown { color: #b8860b; font-weight: 700; }
    .festival-table :global(tr.past) { opacity: 0.55; }
    .festival-table :global(tr.past) .festival-countdown { color: #999; }
    .festival-name { font-weight: 600; white-space: nowrap; }
    .festival-countdown { white-space: nowrap; font-weight: 500; }

    .seo-content { margin-bottom: 3rem; }
    .seo-content h2 { font-size: 1.5rem; color: var(--ink-black); margin-bottom: 1rem; }
    .seo-content p { color: var(--text-muted); line-height: 1.8; margin-bottom: 1rem; }

    .related-tools h2 { font-size: 1.3rem; margin-bottom: 1rem; }
    .related-grid { display: flex; gap: 1rem; flex-wrap: wrap; }
    .related-card { display: flex; align-items: center; gap: 0.6rem; padding: 1rem 1.5rem; background: var(--bg-card); border: 1px solid var(--border); border-radius: 8px; text-decoration: none; color: var(--text); transition: all 0.2s; }
    .related-card:hover { border-color: var(--vermillion); box-shadow: 0 2px 8px rgba(192,57,43,0.1); }
    .related-icon { font-size: 1.5rem; }
    .related-name { font-weight: 600; font-family: var(--font-sans); }

    @media (max-width: 600px) {
      .festival-table th, .festival-table td { padding: 0.5rem 0.3rem; font-size: 0.8rem; }
    }
  </style>
</BaseLayout>
