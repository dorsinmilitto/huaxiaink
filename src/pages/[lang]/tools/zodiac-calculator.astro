---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { type Lang } from '../../../i18n/utils';

export async function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'zh' } }];
}

const { lang } = Astro.params;
const l = lang as Lang;
const isZh = l === 'zh';

const pageData = isZh ? {
  title: '生肖查询器',
  description: '输入出生年份，免费查询你的中国生肖属相、五行属性、天干地支和性格特点，附带生肖配对兼容性分析。',
  h1: '生肖查询器',
  intro: '输入出生年份，查看你的生肖属相、五行属性、阴阳、天干地支纪年，以及性格特点和生肖配对。',
  yearLabel: '出生年份',
  calcBtn: '查询',
  resultTitle: '查询结果',
  zodiacSign: '生肖属相',
  element: '五行属性',
  yinYang: '阴阳',
  ganZhi: '天干地支',
  personality: '性格特点',
  bestMatch: '最佳配对',
  worstMatch: '相冲生肖',
  seoH2: '关于中国十二生肖',
  seoP1: '中国十二生肖以十二地支为基础，依次为鼠、牛、虎、兔、龙、蛇、马、羊、猴、鸡、狗、猪。每十二年一循环，与天干地支纪年法配合，形成六十年一个甲子轮回。',
  seoP2: '十二生肖还与五行（金、木、水、火、土）相对应。每个天干对应一种五行属性，如甲乙属木、丙丁属火、戊己属土、庚辛属金、壬癸属水。五行之间有相生相克的关系，影响着生肖配对的吉凶。',
  seoP3: '生肖配对主要看三合与六合。三合指三个生肖为一组，彼此和谐：申子辰（猴鼠龙）、亥卯未（猪兔羊）、寅午戌（虎马狗）、巳酉丑（蛇鸡牛）。六冲则指相对冲的生肖组合，如子午相冲（鼠马）、丑未相冲（牛羊）等。',
  relatedTitle: '其他工具',
} : {
  title: 'Chinese Zodiac Calculator',
  description: 'Enter your birth year to find your Chinese zodiac animal, Five Elements attribute, GanZhi, personality traits, and zodiac compatibility.',
  h1: 'Chinese Zodiac Calculator',
  intro: 'Enter your birth year to discover your zodiac animal, Five Elements (WuXing), Yin-Yang, GanZhi year, personality traits, and zodiac compatibility.',
  yearLabel: 'Birth Year',
  calcBtn: 'Calculate',
  resultTitle: 'Your Result',
  zodiacSign: 'Zodiac Animal',
  element: 'Five Elements',
  yinYang: 'Yin-Yang',
  ganZhi: 'GanZhi Year',
  personality: 'Personality',
  bestMatch: 'Best Matches',
  worstMatch: 'Clashing Signs',
  seoH2: 'About the Chinese Zodiac',
  seoP1: 'The Chinese zodiac is based on the 12 Earthly Branches, cycling through 12 animals: Rat, Ox, Tiger, Rabbit, Dragon, Snake, Horse, Goat, Monkey, Rooster, Dog, and Pig. Each year is assigned an animal in a 12-year cycle, combined with the 10 Heavenly Stems to form the 60-year Sexagenary Cycle.',
  seoP2: 'Each zodiac year is also associated with one of the Five Elements (Metal, Wood, Water, Fire, Earth). The Heavenly Stem determines the element: Jia-Yi = Wood, Bing-Ding = Fire, Wu-Ji = Earth, Geng-Xin = Metal, Ren-Gui = Water. Elements follow generating and overcoming cycles that influence zodiac compatibility.',
  seoP3: 'Zodiac compatibility is determined by Triple Harmony (San He) and Six Clashes (Liu Chong). Triple Harmony groups: Monkey-Rat-Dragon, Pig-Rabbit-Goat, Tiger-Horse-Dog, Snake-Rooster-Ox. Six Clashes are opposing pairs: Rat-Horse, Ox-Goat, Tiger-Monkey, Rabbit-Rooster, Dragon-Dog, Snake-Pig.',
  relatedTitle: 'Other Tools',
};

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": pageData.title,
  "url": `https://www.huaxiaink.com/${l}/tools/zodiac-calculator/`,
  "description": pageData.description,
  "applicationCategory": "UtilityApplication",
  "operatingSystem": "Web",
  "inLanguage": isZh ? "zh-CN" : "en",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
};
---

<BaseLayout title={pageData.title} description={pageData.description} lang={l}>
  <div class="tool-page">
    <nav class="breadcrumb">
      <a href={`/${l}/`}>{isZh ? '首页' : 'Home'}</a>
      <span class="sep">›</span>
      <a href={`/${l}/tools/`}>{isZh ? '工具' : 'Tools'}</a>
      <span class="sep">›</span>
      <span class="current">{pageData.h1}</span>
    </nav>

    <h1>{pageData.h1}</h1>
    <p class="tool-intro">{pageData.intro}</p>

    <div class="tool-container">
      <div class="form-row">
        <label for="birth-year">{pageData.yearLabel}</label>
        <div class="year-input-row">
          <input type="number" id="birth-year" min="1900" max="2100" value="1990" />
          <button class="calc-btn" id="btn-calc">{pageData.calcBtn}</button>
        </div>
      </div>

      <!-- Zodiac wheel -->
      <div class="zodiac-wheel" id="zodiac-wheel"></div>

      <!-- Result -->
      <div class="result-panel" id="result" style="display:none;">
        <h3>{pageData.resultTitle}</h3>
        <div class="result-main" id="result-main"></div>
      </div>
    </div>

    <section class="seo-content">
      <h2>{pageData.seoH2}</h2>
      <p>{pageData.seoP1}</p>
      <p>{pageData.seoP2}</p>
      <p>{pageData.seoP3}</p>
    </section>

    <section class="related-tools">
      <h2>{pageData.relatedTitle}</h2>
      <div class="related-grid">
        <a href={`/${l}/tools/lunar-converter/`} class="related-card">
          <span class="related-icon">📅</span>
          <span class="related-name">{isZh ? '农历转换器' : 'Lunar Converter'}</span>
        </a>
        <a href={`/${l}/tools/festival-finder/`} class="related-card">
          <span class="related-icon">🧧</span>
          <span class="related-name">{isZh ? '节日查询' : 'Festival Finder'}</span>
        </a>
      </div>
    </section>
  </div>

  <script is:inline src="/js/lunar.js"></script>
  <script is:inline define:vars={{ pd: pageData, isZh }}>
    document.addEventListener('DOMContentLoaded', function() {
      var zodiacZh = ['鼠','牛','虎','兔','龙','蛇','马','羊','猴','鸡','狗','猪'];
      var zodiacEn = ['Rat','Ox','Tiger','Rabbit','Dragon','Snake','Horse','Goat','Monkey','Rooster','Dog','Pig'];
      var zodiacEmoji = ['🐭','🐮','🐯','🐰','🐲','🐍','🐴','🐑','🐵','🐔','🐶','🐷'];

      var elementsZh = ['木','火','土','金','水'];
      var elementsEn = ['Wood','Fire','Earth','Metal','Water'];

      var stemsZh = ['甲','乙','丙','丁','戊','己','庚','辛','壬','癸'];
      var stemsEn = ['Jia','Yi','Bing','Ding','Wu','Ji','Geng','Xin','Ren','Gui'];
      var stemElements = [0,0,1,1,2,2,3,3,4,4]; // indices into elements arrays
      var stemYinYang = ['Yang','Yin','Yang','Yin','Yang','Yin','Yang','Yin','Yang','Yin'];
      var stemYinYangZh = ['阳','阴','阳','阴','阳','阴','阳','阴','阳','阴'];

      // Personality traits
      var traitsZh = [
        '机智灵活，善于交际，注重细节，有很强的适应能力和洞察力',
        '勤劳踏实，责任心强，做事有条不紊，值得信赖，有耐心毅力',
        '勇敢果断，充满自信，具有领导才能，热情大方，喜欢冒险和挑战',
        '温柔善良，心思细腻，富有同情心，追求和谐，审美眼光独到',
        '志向远大，充满活力，具有创造力和想象力，自信果敢，天生有领导魅力',
        '深思熟虑，冷静沉着，直觉敏锐，做事有计划，优雅神秘，追求完美',
        '热情开朗，精力充沛，行动力强，热爱自由，善于表达，人缘极佳',
        '温和善良，富有创意，有艺术天赋，为人正直，注重家庭，内心坚韧',
        '聪明机灵，幽默风趣，好奇心强，学习能力强，善于解决问题，灵活多变',
        '勤奋守时，一丝不苟，观察力强，直言不讳，有责任感，注重外表和秩序',
        '忠诚可靠，正义感强，有保护欲，为人坦诚，工作认真，重情重义',
        '厚道诚实，心地善良，慷慨大方，待人真诚，享受生活，有福气'
      ];
      var traitsEn = [
        'Quick-witted, adaptable, sociable, detail-oriented with strong intuition',
        'Diligent, dependable, methodical, patient, with strong sense of responsibility',
        'Brave, confident, natural leader, charismatic, loves adventure and challenge',
        'Gentle, compassionate, detail-minded, artistic, seeks harmony and beauty',
        'Ambitious, energetic, creative, self-assured, born leader with magnetic charm',
        'Thoughtful, composed, intuitive, systematic, elegant, perfectionist',
        'Enthusiastic, energetic, freedom-loving, expressive, popular and outgoing',
        'Gentle, creative, artistic, honest, family-oriented with inner strength',
        'Clever, humorous, curious, quick learner, versatile problem-solver',
        'Hardworking, punctual, observant, straightforward, responsible, detail-oriented',
        'Loyal, honest, protective, fair-minded, dutiful, values relationships deeply',
        'Honest, kind-hearted, generous, sincere, enjoys life, naturally fortunate'
      ];

      // Compatibility: Triple Harmony groups
      var sanHe = [
        [8,0,4],   // Monkey, Rat, Dragon (申子辰)
        [11,3,7],  // Pig, Rabbit, Goat (亥卯未)
        [2,6,10],  // Tiger, Horse, Dog (寅午戌)
        [5,9,1]    // Snake, Rooster, Ox (巳酉丑)
      ];

      // Six Clashes
      var liuChong = [
        [0,6],  // Rat - Horse
        [1,7],  // Ox - Goat
        [2,8],  // Tiger - Monkey
        [3,9],  // Rabbit - Rooster
        [4,10], // Dragon - Dog
        [5,11]  // Snake - Pig
      ];

      // Build zodiac wheel
      var wheel = document.getElementById('zodiac-wheel');
      var wheelHtml = '';
      for (var i = 0; i < 12; i++) {
        wheelHtml += '<div class="zodiac-item" data-idx="' + i + '">'
          + '<span class="zodiac-emoji">' + zodiacEmoji[i] + '</span>'
          + '<span class="zodiac-name">' + (isZh ? zodiacZh[i] : zodiacEn[i]) + '</span>'
          + '</div>';
      }
      wheel.innerHTML = wheelHtml;

      // Click on zodiac item
      document.querySelectorAll('.zodiac-item').forEach(function(item) {
        item.addEventListener('click', function() {
          var idx = parseInt(item.dataset.idx);
          // Find a year that has this zodiac
          var currentYear = new Date().getFullYear();
          var baseIdx = (currentYear - 4) % 12;
          if (baseIdx < 0) baseIdx += 12;
          var diff = idx - baseIdx;
          if (diff < 0) diff += 12;
          var year = currentYear + diff;
          year = year - 12 * Math.floor((year - 1900) / 24); // keep within reasonable range
          if (year < 1900) year += 12;
          document.getElementById('birth-year').value = year;
          calculate();
        });
      });

      function calculate() {
        var year = parseInt(document.getElementById('birth-year').value);
        if (isNaN(year) || year < 1900 || year > 2100) {
          alert(isZh ? '请输入1900至2100之间的年份' : 'Please enter a year between 1900 and 2100');
          return;
        }

        var solar = Solar.fromYmd(year, 1, 1);
        var lunar = solar.getLunar();
        var ganZhi = lunar.getYearInGanZhi();
        var stemChar = ganZhi.charAt(0);
        var stemIdx = stemsZh.indexOf(stemChar);
        var zodiacChar = lunar.getYearShengXiao();
        var zodiacIdx = zodiacZh.indexOf(zodiacChar);

        var elementIdx = stemElements[stemIdx];
        var element = isZh ? elementsZh[elementIdx] : elementsEn[elementIdx];
        var yinYang = isZh ? stemYinYangZh[stemIdx] : stemYinYang[stemIdx];
        var zodiacName = isZh ? zodiacZh[zodiacIdx] : zodiacEn[zodiacIdx];
        var zodiacEmojiVal = zodiacEmoji[zodiacIdx];
        var personality = isZh ? traitsZh[zodiacIdx] : traitsEn[zodiacIdx];

        // Find best matches (Triple Harmony group, excluding self)
        var bestGroup = sanHe.find(function(g) { return g.indexOf(zodiacIdx) >= 0; });
        var bestMatches = bestGroup.filter(function(i) { return i !== zodiacIdx; })
          .map(function(i) { return zodiacEmoji[i] + ' ' + (isZh ? zodiacZh[i] : zodiacEn[i]); });

        // Find clashing sign
        var clashPair = liuChong.find(function(p) { return p.indexOf(zodiacIdx) >= 0; });
        var clashIdx = clashPair.filter(function(i) { return i !== zodiacIdx; })[0];
        var clashName = zodiacEmoji[clashIdx] + ' ' + (isZh ? zodiacZh[clashIdx] : zodiacEn[clashIdx]);

        // Build result HTML
        var html = '<div class="result-hero">'
          + '<div class="result-zodiac-emoji">' + zodiacEmojiVal + '</div>'
          + '<div class="result-zodiac-name">' + zodiacName + (isZh ? '年' : ' Year') + '</div>'
          + '</div>'
          + '<div class="result-grid">'
          + '<div class="result-row"><span class="result-label">' + pd.ganZhi + '</span><span class="result-value">' + ganZhi + (isZh ? '年' : '') + '</span></div>'
          + '<div class="result-row"><span class="result-label">' + pd.element + '</span><span class="result-value">' + element + (isZh ? '' : ' Element') + '</span></div>'
          + '<div class="result-row"><span class="result-label">' + pd.yinYang + '</span><span class="result-value">' + yinYang + (isZh ? '' : '') + '</span></div>'
          + '<div class="result-row"><span class="result-label">' + pd.bestMatch + '</span><span class="result-value">' + bestMatches.join('、') + '</span></div>'
          + '<div class="result-row"><span class="result-label">' + pd.worstMatch + '</span><span class="result-value">' + clashName + '</span></div>'
          + '</div>'
          + '<div class="result-personality">'
          + '<div class="result-label-bold">' + pd.personality + '</div>'
          + '<p>' + personality + '</p>'
          + '</div>';

        document.getElementById('result-main').innerHTML = html;
        document.getElementById('result').style.display = 'block';

        // Highlight selected zodiac in wheel
        document.querySelectorAll('.zodiac-item').forEach(function(item) {
          item.classList.toggle('active', parseInt(item.dataset.idx) === zodiacIdx);
        });
      }

      document.getElementById('btn-calc').addEventListener('click', calculate);
      document.getElementById('birth-year').addEventListener('keydown', function(e) {
        if (e.key === 'Enter') calculate();
      });

      // Auto-calculate on load
      calculate();
    });
  </script>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <style>
    .tool-page { max-width: 800px; margin: 0 auto; padding: 2rem 1.5rem 4rem; }
    .breadcrumb { font-family: var(--font-sans); font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1.5rem; }
    .breadcrumb a { color: var(--link); }
    .breadcrumb .sep { margin: 0 0.5rem; }
    .breadcrumb .current { color: var(--text); }
    .tool-page h1 { font-size: 2rem; color: var(--ink-black); margin-bottom: 0.5rem; }
    .tool-intro { color: var(--text-muted); font-size: 1rem; margin-bottom: 2rem; }

    .tool-container {
      background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px;
      padding: 2rem; box-shadow: 0 2px 8px rgba(0,0,0,0.06); margin-bottom: 3rem;
    }

    .form-row { margin-bottom: 1.5rem; }
    .form-row label { display: block; font-family: var(--font-sans); font-size: 0.9rem; color: var(--text-muted); margin-bottom: 0.5rem; font-weight: 500; }
    .year-input-row { display: flex; gap: 1rem; }
    .year-input-row input {
      flex: 1; padding: 0.7rem 1rem; border: 1px solid var(--border); border-radius: 8px;
      font-size: 1rem; font-family: var(--font-sans); background: #fff; color: var(--text);
    }
    .year-input-row input:focus { outline: none; border-color: var(--vermillion); box-shadow: 0 0 0 3px rgba(192,57,43,0.1); }
    .calc-btn {
      padding: 0.7rem 2rem; border: none; border-radius: 8px;
      background: var(--vermillion); color: #fff; font-size: 1rem; font-weight: 600;
      font-family: var(--font-sans); cursor: pointer; transition: background 0.2s; white-space: nowrap;
    }
    .calc-btn:hover { background: var(--accent-hover); }

    .zodiac-wheel {
      display: grid; grid-template-columns: repeat(6, 1fr); gap: 0.5rem;
      margin-bottom: 1.5rem; padding: 1rem; background: #fff; border-radius: 8px; border: 1px solid var(--border);
    }
    .zodiac-item {
      display: flex; flex-direction: column; align-items: center; gap: 0.3rem;
      padding: 0.6rem 0.3rem; border-radius: 8px; cursor: pointer; transition: all 0.2s;
    }
    .zodiac-item:hover { background: var(--pale-ink); }
    .zodiac-item.active { background: rgba(192,57,43,0.1); border: 2px solid var(--vermillion); }
    .zodiac-emoji { font-size: 1.8rem; line-height: 1; }
    .zodiac-name { font-family: var(--font-sans); font-size: 0.75rem; color: var(--text-muted); }

    .result-panel { margin-top: 1.5rem; padding: 1.5rem; background: #fff; border-radius: 8px; border: 1px solid var(--border); }
    .result-panel h3 { font-size: 1.1rem; color: var(--ink-black); margin-bottom: 1rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(--border); }

    .result-hero { text-align: center; margin-bottom: 1.5rem; }
    .result-zodiac-emoji { font-size: 4rem; line-height: 1; }
    .result-zodiac-name { font-size: 1.5rem; font-weight: 700; color: var(--vermillion); margin-top: 0.3rem; }

    .result-grid { margin-bottom: 1.5rem; }
    .result-row { display: flex; justify-content: space-between; align-items: center; padding: 0.5rem 0; border-bottom: 1px solid #f0ebe0; gap: 1rem; }
    .result-row:last-child { border-bottom: none; }
    .result-label { font-family: var(--font-sans); font-size: 0.9rem; color: var(--text-muted); flex-shrink: 0; }
    .result-value { font-size: 1rem; color: var(--text); font-weight: 600; text-align: right; }

    .result-personality { padding-top: 1rem; border-top: 1px solid var(--border); }
    .result-label-bold { font-family: var(--font-sans); font-size: 0.9rem; color: var(--text-muted); font-weight: 600; margin-bottom: 0.3rem; }
    .result-personality p { font-size: 0.95rem; line-height: 1.7; color: var(--text); }

    .seo-content { margin-bottom: 3rem; }
    .seo-content h2 { font-size: 1.5rem; color: var(--ink-black); margin-bottom: 1rem; }
    .seo-content p { color: var(--text-muted); line-height: 1.8; margin-bottom: 1rem; }

    .related-tools h2 { font-size: 1.3rem; margin-bottom: 1rem; }
    .related-grid { display: flex; gap: 1rem; flex-wrap: wrap; }
    .related-card { display: flex; align-items: center; gap: 0.6rem; padding: 1rem 1.5rem; background: var(--bg-card); border: 1px solid var(--border); border-radius: 8px; text-decoration: none; color: var(--text); transition: all 0.2s; }
    .related-card:hover { border-color: var(--vermillion); box-shadow: 0 2px 8px rgba(192,57,43,0.1); }
    .related-icon { font-size: 1.5rem; }
    .related-name { font-weight: 600; font-family: var(--font-sans); }

    @media (max-width: 600px) {
      .zodiac-wheel { grid-template-columns: repeat(4, 1fr); }
      .year-input-row { flex-direction: column; }
    }
  </style>
</BaseLayout>
