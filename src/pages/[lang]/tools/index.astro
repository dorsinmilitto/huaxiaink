---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { type Lang } from '../../../i18n/utils';

export async function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'zh' } }];
}

const { lang } = Astro.params;
const l = lang as Lang;
const isZh = l === 'zh';

const pageData = isZh ? {
  title: '中国传统日历工具',
  description: '免费在线中国日历工具集：农历阳历转换器、生肖查询器、传统节日查询。精准计算1900-2100年农历日期。',
  h1: '中国传统日历工具',
  intro: '精选实用中国日历工具，帮助你轻松查询农历日期、生肖属相和传统节日，了解中国历法文化。',
  seoH2: '为什么使用这些工具？',
  seoP1: '中国使用独特的阴阳合历系统已有数千年历史。这套历法不仅用于标记日期，还与二十四节气、生肖文化、传统节日和民间习俗紧密相连。无论你是查阅农历生日、了解生肖文化，还是计划节日行程，这些工具都能提供精准的参考。',
  seoP2: '所有工具均基于专业级天文算法计算，数据覆盖1900年至2100年，结果准确可靠。完全免费，无需注册，支持中英双语。',
} : {
  title: 'Chinese Calendar Tools',
  description: 'Free online Chinese calendar tools: lunar calendar converter, zodiac calculator, and traditional festival finder. Accurate from 1900 to 2100.',
  h1: 'Chinese Calendar Tools',
  intro: 'A collection of practical Chinese calendar tools to help you convert lunar dates, look up zodiac signs, and find traditional festival dates.',
  seoH2: 'Why Use These Tools?',
  seoP1: 'China has used a unique lunisolar calendar system for thousands of years. This calendar is not just for dating — it is deeply connected to the 24 solar terms, zodiac culture, traditional festivals, and folk customs. Whether you are looking up a lunar birthday, exploring zodiac culture, or planning for festivals, these tools provide accurate references.',
  seoP2: 'All tools are based on professional-grade astronomical algorithms with data covering 1900–2100. Completely free, no registration required, available in both English and Chinese.',
};

const tools = isZh ? [
  { href: `/${l}/tools/lunar-converter/`, emoji: '📅', name: '农历阳历转换器', desc: '公历与农历双向转换，显示天干地支、生肖、节气' },
  { href: `/${l}/tools/zodiac-calculator/`, emoji: '🐉', name: '生肖查询器', desc: '输入年份查询生肖属相、五行属性及配对兼容性' },
  { href: `/${l}/tools/festival-finder/`, emoji: '🧧', name: '传统节日查询', desc: '查看任意年份中国传统节日的公历日期和倒计时' },
] : [
  { href: `/${l}/tools/lunar-converter/`, emoji: '📅', name: 'Lunar Calendar Converter', desc: 'Convert between Gregorian and Chinese lunar dates with GanZhi and solar terms' },
  { href: `/${l}/tools/zodiac-calculator/`, emoji: '🐉', name: 'Zodiac Calculator', desc: 'Find your Chinese zodiac animal, Five Elements, and compatibility' },
  { href: `/${l}/tools/festival-finder/`, emoji: '🧧', name: 'Festival Finder', desc: 'Get Gregorian dates for all major Chinese festivals in any year' },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": pageData.title,
  "url": `https://www.huaxiaink.com/${l}/tools/`,
  "itemListElement": tools.map((t, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "WebApplication",
      "name": t.name,
      "url": `https://www.huaxiaink.com${t.href}`,
      "description": t.desc,
      "applicationCategory": "UtilityApplication",
      "operatingSystem": "Web",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    }
  })),
};
---

<BaseLayout title={pageData.title} description={pageData.description} lang={l}>
  <div class="tool-page">
    <nav class="breadcrumb">
      <a href={`/${l}/`}>{isZh ? '首页' : 'Home'}</a>
      <span class="sep">›</span>
      <span class="current">{isZh ? '工具' : 'Tools'}</span>
    </nav>

    <h1>{pageData.h1}</h1>
    <p class="tool-intro">{pageData.intro}</p>

    <div class="tools-grid">
      {tools.map(tool => (
        <a href={tool.href} class="tool-card">
          <div class="tool-card-emoji">{tool.emoji}</div>
          <h2 class="tool-card-name">{tool.name}</h2>
          <p class="tool-card-desc">{tool.desc}</p>
          <span class="tool-card-link">{isZh ? '使用工具 →' : 'Use Tool →'}</span>
        </a>
      ))}
    </div>

    <section class="seo-content">
      <h2>{pageData.seoH2}</h2>
      <p>{pageData.seoP1}</p>
      <p>{pageData.seoP2}</p>
    </section>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <style>
    .tool-page { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem 4rem; }
    .breadcrumb { font-family: var(--font-sans); font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1.5rem; }
    .breadcrumb a { color: var(--link); }
    .breadcrumb .sep { margin: 0 0.5rem; }
    .breadcrumb .current { color: var(--text); }
    .tool-page h1 { font-size: 2.2rem; color: var(--ink-black); margin-bottom: 0.5rem; }
    .tool-intro { color: var(--text-muted); font-size: 1.05rem; margin-bottom: 2.5rem; }

    .tools-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 1.5rem; margin-bottom: 3rem;
    }
    .tool-card {
      display: flex; flex-direction: column; align-items: center; text-align: center;
      padding: 2rem 1.5rem; background: var(--bg-card); border: 1px solid var(--border);
      border-radius: 12px; text-decoration: none; color: var(--text); transition: all 0.3s;
      box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    }
    .tool-card:hover {
      border-color: var(--vermillion); box-shadow: 0 4px 16px rgba(192,57,43,0.12);
      transform: translateY(-2px);
    }
    .tool-card-emoji { font-size: 3rem; line-height: 1; margin-bottom: 1rem; }
    .tool-card-name { font-size: 1.2rem; color: var(--ink-black); margin-bottom: 0.5rem; font-weight: 700; }
    .tool-card-desc { font-size: 0.9rem; color: var(--text-muted); line-height: 1.6; margin-bottom: 1rem; flex: 1; font-family: var(--font-sans); }
    .tool-card-link { font-size: 0.9rem; color: var(--vermillion); font-weight: 600; font-family: var(--font-sans); }

    .seo-content { margin-bottom: 2rem; }
    .seo-content h2 { font-size: 1.5rem; color: var(--ink-black); margin-bottom: 1rem; }
    .seo-content p { color: var(--text-muted); line-height: 1.8; margin-bottom: 1rem; }
  </style>
</BaseLayout>
