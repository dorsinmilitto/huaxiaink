---
// Root redirect: detect browser language, redirect to /en or /zh
---
<html>
<head>
  <meta charset="UTF-8" />
  <script is:inline>
    (function() {
      var lang = 'en';
      try {
        var nav = navigator.language || navigator.userLanguage || '';
        if (nav.toLowerCase().indexOf('zh') === 0) lang = 'zh';
      } catch(e) {}
      // Check localStorage for saved preference
      try {
        var saved = localStorage.getItem('huaxiaink-lang');
        if (saved === 'zh' || saved === 'en') lang = saved;
      } catch(e) {}
      location.replace('/' + lang + '/');
    })();
  </script>
  <noscript>
    <meta http-equiv="refresh" content="0;url=/en/" />
  </noscript>
</head>
<body></body>
</html>
